{
  "title": "NexusFeed - API Health",
  "uid": "nexusfeed-api-health",
  "panels": [
    {
      "title": "Feed Latency (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(nexusfeed_feed_latency_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(nexusfeed_feed_latency_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(nexusfeed_feed_latency_seconds_bucket[5m]))", "legendFormat": "p99" }
      ]
    },
    {
      "title": "Events Latency (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.99, rate(nexusfeed_events_latency_seconds_bucket[5m]))", "legendFormat": "p99" }
      ]
    },
    {
      "title": "Requests In Flight",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{ "expr": "nexusfeed_in_flight_requests", "legendFormat": "{{route}}" }]
    },
    {
      "title": "Rate Limit Rejections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{ "expr": "rate(nexusfeed_rate_limit_rejections_total[5m])", "legendFormat": "rejections/s" }]
    }
  ],
  "schemaVersion": 39,
  "time": { "from": "now-1h", "to": "now" }
}
