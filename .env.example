# Copy to .env and adjust for your environment. Every value here has a safe
# local-dev default baked into nexusfeed/config.py — you only need to
# override what differs from docker-compose defaults.

# --- App ---
ENV=local                      # local | staging | production
LOG_LEVEL=INFO
LOG_FORMAT=json                # json | console

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
VALID_API_KEYS=dev-key-local-only   # comma-separated; use a secrets manager in prod
RATE_LIMIT_EVENTS_PER_SECOND=100

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=nexusfeed-feature-pipeline

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- PostgreSQL ---
# POSTGRES_USER/PASSWORD/DB feed the postgres container in docker-compose.yml;
# DATABASE_URL is what the API/worker/alembic actually connect with. Change
# all four together if you change credentials — replace these before any
# non-local deployment, they are dev-only defaults.
POSTGRES_USER=nexusfeed
POSTGRES_PASSWORD=nexusfeed
POSTGRES_DB=nexusfeed
DATABASE_URL=postgresql+asyncpg://nexusfeed:nexusfeed@localhost:5432/nexusfeed

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=nexusfeed

# --- S3 / object storage (use localstack or MinIO for local dev) ---
S3_BUCKET=nexusfeed-artifacts-local
S3_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1

# --- Model / ML ---
EMBEDDING_DIM=128
MODEL_REGISTRY_URI=sqlite:///./mlflow.db
ANN_INDEX_PATH=./data/faiss_index.bin
RANKING_MODEL_PATH=./data/ranking_model.txt

# --- A/B testing ---
AB_MIN_DETECTABLE_EFFECT=0.02
BANDIT_EPSILON=0.10
HOLDBACK_FRACTION=0.05

# --- Observability ---
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
